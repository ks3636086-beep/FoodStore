<%@ Page Title="" Language="C#" MasterPageFile="~/MasterPage.master" AutoEventWireup="true" CodeFile="wishlist.aspx.cs" Inherits="wishlist" %>

<asp:Content ID="Content1" ContentPlaceHolderID="head" runat="Server">
    <style>
        .delete-btn {
            color: black !important;
            padding: 8px 14px;
            border-radius: 5px;
        }
    </style>
</asp:Content>
<asp:Content ID="Content2" ContentPlaceHolderID="ContentPlaceHolder1" runat="Server">
    <!-- Start All Title Box -->
    <div class="all-title-box">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <h2>Wishlist</h2>
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="#">Shop</a></li>
                        <li class="breadcrumb-item active">Wishlist</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <!-- End All Title Box -->

    <!-- Start Wishlist  -->
    <div class="wishlist-box-main">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="table-main table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Images</th>
                                    <th>Product Name</th>
                                    <th>Unit Price </th>
                                    <th>Stock</th>
                                    <th>Add Item</th>
                                    <th>Remove</th>
                                </tr>
                            </thead>
                            <tbody>
                                <asp:Repeater ID="rptWishlist" runat="server">
                                    <ItemTemplate>
                                        <tr>
                                            <td class="thumbnail-img">

                                                <img class="img-fluid" src='auth/<%# Eval("photo_path") %>' alt="" />

                                            </td>
                                            <td class="name-pr">
                                                <%# Eval("product_full_name") %>
                                            </td>
                                            <td class="price-pr">
                                                <%# Eval("product_final_sell_price") %>
                                            </td>
                                            <td class="quantity-box">In Stock</td>

                                            <td class="add-pr">
                                                <a class="btn hvr-hover" href="#">Add to Cart</a>
                                            </td>
                                            <td class="add-pr">
                                                <asp:LinkButton ID="btnDelete" class="btn hvr-hover" CssClass="delete-btn" runat="server"
                                                    CommandArgument='<%# Eval("id") %>'
                                                    OnCommand="btnDelete_Command" OnClientClick="return confirm('Are you sure you want to remove this item?');"> 
                                                    <i class="fas fa-trash"></i>
                                                      
                                              </asp:LinkButton>
                                            </td>
                                        </tr>
                                    </ItemTemplate>
                                </asp:Repeater>

                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
 
        </div>
    </div>
    <!-- End Wishlist -->




